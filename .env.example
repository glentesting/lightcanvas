# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Required for Claude sequence generation (Vercel serverless: api/generate-sequence.ts) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override Claude model (default claude-3-5-sonnet-20241022)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Optional: full URL to the generate-sequence endpoint (production / custom deploy)
# VITE_GENERATE_SEQUENCE_URL=https://your-app.vercel.app/api/generate-sequence

# Local dev: Vite proxies /api/* to this target — use `vercel dev` (default port 3000) or your backend
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
